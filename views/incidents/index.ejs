<%- include('../partials/header') %>

<section class="hero">
  <div class="section-head">
    <h2>Hendelser</h2>
    <% if (currentUser && currentUser.role === 'admin') { %>
      <a href="/incidents/new" class="btn">+ Ny hendelse</a>
    <% } %>
  </div>

  <form method="GET" action="/incidents" class="filter-bar">
    <select name="status">
      <option value="">Alle statuser</option>
      <% statuses.forEach(s => { %>
        <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>

    <select name="priority">
      <option value="">All kritikalitet</option>
      <% priorities.forEach(p => { %>
        <option value="<%= p %>" <%= filters.priority === p ? 'selected' : '' %>><%= p %></option>
      <% }) %>
    </select>

    <select name="category">
      <option value="">Alle kategorier</option>
      <% categories.forEach(c => { %>
        <option value="<%= c %>" <%= filters.category === c ? 'selected' : '' %>><%= c %></option>
      <% }) %>
    </select>

    <button type="submit" class="btn">Filtrer</button>
    <a href="/incidents" class="cancel">Nullstill</a>
  </form>

  <table class="table">
    <thead>
      <tr>
        <th>Tittel</th>
        <th>Kategori</th>
        <th>Kritikalitet</th>
        <th>Status</th>
        <th>Ansvarlig</th>
        <th>Opprettet av</th>
        <th>Dato</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% incidents.forEach(i => {
        const priorityMap = { 'Lav': 'low', 'Middels': 'medium', 'Høy': 'high', 'Kritisk': 'critical' };
        const statusMap   = { 'Åpen': 'open', 'Under arbeid': 'progress', 'Løst': 'resolved' };
      %>
        <tr>
          <td><%= i.title %></td>
          <td><%= i.category %></td>
          <td><span class="badge priority-<%= priorityMap[i.priority] %>"><%= i.priority %></span></td>
          <td><span class="badge status-<%= statusMap[i.status] %>"><%= i.status %></span></td>
          <td><%= i.assignedTo ? i.assignedTo.name : '—' %></td>
          <td><%= i.createdBy ? i.createdBy.name : '—' %></td>
          <td><%= i.createdAt.toLocaleDateString('no-NO') %></td>
          <td><a href="/incidents/<%= i._id %>">Åpne</a></td>
        </tr>
      <% }) %>
      <% if (incidents.length === 0) { %>
        <tr><td colspan="8" class="muted">Ingen hendelser ennå.</td></tr>
      <% } %>
    </tbody>
  </table>
</section>

<%- include('../partials/footer') %>
