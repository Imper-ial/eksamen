<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="topbar">
    <div class="container">
      <h1 class="brand">Kommune 69 Varslingssystem</h1>
      <nav class="nav">
        <a href="/">Forside</a>
        <% if (currentUser) { %>
          <a href="/dashboard">Dashboard</a>
