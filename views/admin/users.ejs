<%- include('../partials/header') %>

<section class="hero">
  <h2>Administrasjon</h2>
  <div class="admin-actions">
    <a href="/admin/users/new" class="btn">+ Opprett ny bruker</a>
    <a href="/incidents/new" class="btn">+ Opprett ny hendelse</a>
  </div>
</section>

<section class="hero">
  <div class="section-head">
    <h3>Brukere</h3>
  </div>

  <table class="table">
    <thead>
      <tr>
        <th>Fullt navn</th>
        <th>Rolle</th>
        <th>Opprettet</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td><%= u.name %></td>
          <td><%= roleLabel(u.role) %></td>
          <td><%= u.createdAt.toLocaleDateString('no-NO') %></td>
        </tr>
      <% }) %>
      <% if (users.length === 0) { %>
        <tr><td colspan="3" class="muted">Ingen brukere ennå.</td></tr>
      <% } %>
    </tbody>
  </table>
</section>

<%- include('../partials/footer') %>
